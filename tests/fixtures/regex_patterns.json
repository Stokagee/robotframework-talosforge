{
  "type": "object",
  "properties": {
    "postal_code": {
      "type": "string",
      "pattern": "^\\d{5}$",
      "description": "Czech postal code with rstr"
    },
    "phone_number": {
      "type": "string",
      "pattern": "^[0-9]{9}$",
      "minLength": 9,
      "maxLength": 9,
      "description": "Czech phone number without prefix"
    },
    "username": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_]+$",
      "minLength": 5,
      "maxLength": 15,
      "description": "Username with alphanumeric characters"
    },
    "custom_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}\\d{4}$",
      "description": "Custom code not recognized by context parser - tests pure rstr"
    },
    "custom_id": {
      "type": "string",
      "pattern": "^ID-\\d{3}-[A-Z]{2}$",
      "minLength": 9,
      "maxLength": 9,
      "description": "Custom ID format - tests pure rstr with constraints"
    }
  },
  "required": ["username", "custom_code", "custom_id"]
}
